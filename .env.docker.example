# Copy this file to .env.docker and fill in your real values.
# The file .env.docker is in .gitignore — never commit it.
# Carry .env.docker on a USB drive when moving between computers.

# ── Google OAuth ────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Make sure these Authorized redirect URIs are added to your OAuth app:
#   http://localhost:4000/api/auth/google/callback
#   http://localhost:4000/api/google/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OpenAI ──────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano

# ── JWT Secret ──────────────────────────────────────────────────────────────
# Any random string — used to sign user login tokens
JWT_SECRET=change_this_to_something_random_123

# ── Admin dashboard ─────────────────────────────────────────────────────────
# Comma-separated emails that can access the /admin page
ADMIN_EMAILS=
